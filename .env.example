# VMware Configuration

# VMware API authentication username.
# Default: unset (required).
VCENTER_USERNAME=

# VMware API authentication password.
# Default: unset (required).
VCENTER_PASSWORD=

# Include link-local IPs (fe80::/10 and 169.254.0.0/16) in sync.
# Default: false
# TRACK_LINK_LOCAL_IPS=false

# Number of days before deleting stale decommissioning VMs.
# Default: 5
# DECOM_DAYS=5

# Max concurrent vCenter workers in main sync loop.
# Default: 3
# MAX_VCENTER_WORKERS=3

# Max concurrent host workers per vCenter processing pass.
# Default: 5
# MAX_HOST_WORKERS=5

# PYNETBOX2 Configuration

# NetBox base URL used by the sync and pynetbox2 client.
# Default: https://netbox.example.com
NETBOX_URL=https://netbox.example.com

# NetBox API token used by the sync and pynetbox2 client.
# Default: unset (required for real sync).
NETBOX_TOKEN=

# NetBox backend mode for pynetbox2 (pynetbox or diode).
# Default: pynetbox
NETBOX_BACKEND=pynetbox

# NetBox branch name used for branch-aware reads/writes.
# Default: unset (no branch routing).
# NETBOX_BRANCH=

# Cache backend for pynetbox2 (none, redis, sqlite).
# Default: sqlite
NETBOX_CACHE_BACKEND=none

# Cache TTL in seconds for cached NetBox read objects.
# Default: 3600
# NETBOX_CACHE_TTL_SECONDS=3600

# Cache key prefix namespace to isolate this sync's entries.
# Default: netbox:
# NETBOX_CACHE_KEY_PREFIX=netbox:

# Redis connection URL when NETBOX_CACHE_BACKEND=redis.
# Default: redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# SQLite cache file path when NETBOX_CACHE_BACKEND=sqlite.
# Default: .netbox_cache.sqlite3
# NETBOX_SQLITE_CACHE_PATH=.netbox_cache.sqlite3

# API throttling limit per second per connection (0 disables throttling).
# Default: 0
NETBOX_RATE_LIMIT_PER_SECOND=0

# Token-bucket burst size for API throttling.
# Default: 1
# NETBOX_RATE_LIMIT_BURST=1

# Retry attempts for transient API failures.
# Default: 3
# NETBOX_RETRY_ATTEMPTS=3

# Initial retry backoff delay in seconds.
# Default: 0.3
# NETBOX_RETRY_INITIAL_DELAY=0.3

# Exponential backoff factor for retries.
# Default: 2.0
# NETBOX_RETRY_BACKOFF_FACTOR=2.0

# Maximum retry delay in seconds.
# Default: 15.0
# NETBOX_RETRY_MAX_DELAY=15.0

# Additional random retry jitter in seconds.
# Default: 0.0
# NETBOX_RETRY_JITTER=0.0

# Diode endpoint URL when NETBOX_BACKEND=diode.
# Default: grpcs://localhost:8080
# DIODE_URL=grpcs://localhost:8080

# Diode client ID for authenticated diode access.
# Default: empty
# DIODE_CLIENT_ID=

# Diode client secret for authenticated diode access.
# Default: empty
# DIODE_CLIENT_SECRET=

# Path to TLS cert file for diode connection.
# Default: unset
# DIODE_CERT_FILE=

# Skip TLS verification for diode connection.
# Default: false
# DIODE_SKIP_TLS_VERIFY=false

# Enable REST read fallback when diode backend is selected.
# Default: false
# DIODE_READ_FALLBACK=false